# ─────────────────────────────────────────────────────────────────────────────
# LabOS — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the filled-in .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required by all three agents (literature, hypothesis, procedure) and the
# orchestrator. Obtain from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Tavily (legacy / main.py only) ────────────────────────────────────────────
# Used only by the standalone main.py prototype (not the production pipeline).
# Obtain from https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Google / Gemini (Pipeline B only) ────────────────────────────────────────
# Used by the PubMed + Ragie pipeline (run_pipeline.py).
# Obtain from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Ragie (Pipeline B only) ───────────────────────────────────────────────────
# Used by research_lab/rag.py for RAG indexing.
# Obtain from https://app.ragie.ai
RAGIE_API_KEY=your_ragie_api_key_here

# ── PubMed / Entrez (Pipeline B only) ────────────────────────────────────────
# Required by Biopython's Entrez API to identify your requests.
ENTREZ_EMAIL=your_email@example.com

# ── Supabase — Python Backend ─────────────────────────────────────────────────
# Used exclusively in research_lab/supabase_client.py.
# The service role key bypasses RLS — NEVER expose it in frontend code or logs.
# Obtain both values from your Supabase project: Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Supabase — React Mockup ───────────────────────────────────────────────────
# Used in labos-mockup/src/lib/supabase.js via import.meta.env.
# The anon key is safe to expose in the browser — RLS enforces access control.
# Obtain both values from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
